        // Ard plow — wooden draft-animal plow implement. Crafted from
        // wood + tools at a Workbench, gated on `ARD_PLOW` tech. Held in
        // faction storage; the chief plow dispatcher gates on a non-zero
        // count. Plow executor does NOT consume the implement — one plow
        // serves many seasons (its decay surfaces as a v2.1 follow-up).
        ResourceDef(
            key: "ard_plow",
            display_name: "Ard Plow",
            class: tool,
            bulk: two_hand,
            weight_g: 5000,
            entertainment_value: 10,
            storage_class: armoury,
            trade_base_value: 60,
            tags: ["tool", "manufactured", "draftwork"],
            sprite_key: Some("item_hammer"),
        ),

        // ── Cart parts (Animal Husbandry v2.1) ────────────────────────
        // Composable cart components. Crafted independently at a
        // Workbench, then `cart::cart_assembly_system` consumes
        // `1 frame + 2 wheels` from faction storage to spawn a parked
        // `Cart` entity. Effective capacity / speed derive from the
        // frame + wheel material combination (`cart::derive_cart_stats`).
        ResourceDef(
            key: "cart_frame_small",
            display_name: "Cart Frame (Small)",
            class: material,
            bulk: two_hand,
            weight_g: 10000,
            entertainment_value: 0,
            storage_class: pile,
            trade_base_value: 35,
            tags: ["material", "manufactured", "draftwork", "cart_part"],
