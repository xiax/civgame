        // ── Nomadic kit ───────────────────────────────────────────────
        // Packable inventory forms of nomadic structures. A Bedroll lives
        // in inventory between camps; deploying it spawns a 1-tile Bed
        // entity carrying the `Deployable` marker. PackedTent / PackedYurt
        // are the inventory forms of full-shelter Tents / Yurts.
        ResourceDef(
            key: "bedroll",
            display_name: "Bedroll",
            class: material,
            bulk: small,
            weight_g: 1500,
            entertainment_value: 0,
            storage_class: pile,
            trade_base_value: 8,
            tags: ["nomadic", "packed_shelter"],
            sprite_key: Some("item_cloth"),
        ),
        ResourceDef(
            key: "packed_yurt",
            display_name: "Packed Yurt",
            class: material,
            bulk: two_hand,
            // Heavy bundle of felt + wooden lattice + roof poles. Two pack
            // animals saturate on one packed yurt at standard horse capacity.
            weight_g: 80000,
            entertainment_value: 0,
            storage_class: pile,
            trade_base_value: 60,
            tags: ["nomadic", "packed_shelter"],
            sprite_key: Some("item_cloth"),
        ),

        // ── Water ─────────────────────────────────────────────────────
        // Drinking water tracked as inventory/storage resource. One unit
        // = one drink. Clean (potable, no sickness risk) vs raw (from
        // turbid lake / marsh; rolls sickness when drunk without boiling).
        // 500 g/unit so a 5-unit reserve weighs 2.5 kg, similar to a
        // small waterskin. Ocean Water tiles classified as `WaterKind::Salt`
        // by `water_kind_at` reject collection entirely.
        ResourceDef(
            key: "clean_water",
            display_name: "Clean Water",
            class: material,
            bulk: small,
            weight_g: 500,
            entertainment_value: 0,
            storage_class: granary,
            trade_base_value: 1,
            tags: ["water", "potable", "drinkable"],
            sprite_key: Some("resource_seed"),
        ),
        ResourceDef(
            key: "raw_water",
            display_name: "Raw Water",
            class: material,
            bulk: small,
            weight_g: 500,
            entertainment_value: 0,
            storage_class: granary,
            trade_base_value: 0,
            tags: ["water", "raw", "drinkable", "sickness_risk"],
            sprite_key: Some("resource_seed"),
        ),

        // ── Migration ration ──────────────────────────────────────────
        // Smoke-cured meat. Half the calories of fresh, but a quarter of
        // the weight per food-unit and doesn't perish, so nomadic bands
        // pack it for migration journeys. `pick_food_to_eat` prefers
        // fresh / berry / grain over preserved at decision time so the
        // ration stays banked until the band actually leaves camp.
        ResourceDef(
            key: "preserved_meat",
            display_name: "Preserved Meat",
            class: food,
            bulk: small,
            weight_g: 200,
            edible_calories: Some(120),
            entertainment_value: 2,
            storage_class: granary,
            trade_base_value: 8,
            tags: ["food", "edible", "preserved", "ration"],
            sprite_key: Some("resource_meat"),
        ),
