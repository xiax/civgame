// Core resource catalog (Phase 2a).
//
// One entry per Good variant currently defined in src/economy/goods.rs.
// Attributes mirror the per-Good methods (`bulk`, `unit_weight_g`,
// `nutrition`, `entertainment_value`, `is_seed`/`PlantKind::seed_good`).
//
// IDs are assigned alphabetically by `key` at load time, so the order
// of entries here is irrelevant — entries are listed grouped-by-class
// for editor ergonomics. Adding a new resource is a one-RON-entry
// change; no Rust source needs to recompile until phase 2b/2c migrate
// the consumers off of the legacy `Good` enum.
ResourceFile(
    resources: [
        // ── Food ──────────────────────────────────────────────────────
        ResourceDef(
            key: "fruit",
            display_name: "Fruit",
            class: food,
            bulk: small,
            weight_g: 250,
            edible_calories: Some(85),
            entertainment_value: 3,
            storage_class: granary,
            trade_base_value: 5,
            tags: ["food", "edible", "perishable"],
            sprite_key: Some("resource_berries"),
        ),
        ResourceDef(
            key: "meat",
            display_name: "Meat",
