                CellDef(x: 0, y: 1, z: 0, kind: wheel,     material: "wood"),
                CellDef(x: 1, y: 1, z: 0, kind: axle,      material: "wood"),
                CellDef(x: 2, y: 1, z: 0, kind: wheel,     material: "wood"),
                CellDef(x: 0, y: 2, z: 0, kind: cargo_bay, material: "wood"),
                CellDef(x: 1, y: 2, z: 0, kind: cargo_bay, material: "wood"),
                CellDef(x: 2, y: 2, z: 0, kind: cargo_bay, material: "wood"),
                CellDef(x: 0, y: 3, z: 0, kind: wheel,     material: "wood"),
                CellDef(x: 1, y: 3, z: 0, kind: axle,      material: "wood"),
